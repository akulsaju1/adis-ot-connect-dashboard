# ADIS OT Connect Dashboard - Raspberry Pi Environment Configuration
# Copy this file to .env.local on your Raspberry Pi

# Node Environment
NODE_ENV=production

# Application Port
PORT=3000

# Database Configuration (Local JSON)
DATABASE_URL=local

# Better Auth Secret (Generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-generated-secret-here

# Base URLs for Local Access
NEXT_PUBLIC_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Local Data Directory (where all student/staff/dismissal data is stored)
LOCAL_DB_DIR=/home/pi/adis-ot-data/.data

# Optional: For Network Access (set to your Pi's IP address if accessing from other devices)
# NEXT_PUBLIC_BASE_URL=http://192.168.1.100:3000

# Performance Settings for Raspberry Pi
# Reduce worker threads for Pi 4 (2-4GB RAM)
MAX_WORKERS=2

# Database connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=5

# Enable compression for smaller memory footprint
COMPRESS_RESPONSES=true

# Cache settings (in seconds)
CACHE_DURATION=3600

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# Session timeout (in seconds) - 7 days
SESSION_TIMEOUT=604800
